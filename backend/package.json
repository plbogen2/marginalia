{
  "name": "marginalia-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_OPTIONS=\"--experimental-sqlite\" tsx watch src/server.ts",
    "build": "tsc",
    "start": "NODE_OPTIONS=\"--experimental-sqlite\" node dist/server.js",
    "test": "NODE_ENV=test NODE_OPTIONS=\"--experimental-sqlite\" tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
